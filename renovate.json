{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "groupName": "quarkus",
      "matchPackageNames": [
        "/^io\\.quarkus/",
        "/^quarkus/"
      ]
    },
    {
      "groupName": "quarkiverse",
      "matchPackageNames": [
        "/^io\\.quarkiverse/"
      ]
    },
    {
      "groupName": "mvnpm",
      "matchPackageNames": [
        "/^org\\.mvnpm/",
        "!org.mvnpm:react",
        "!org.mvnpm:react-dom",
        "!org.mvnpm:react-bootstrap",
        "!org.mvnpm:classnames",
        "!org.mvnpm:hooks",
        "!org.mvnpm.at.types:react",
        "!org.mvnpm:styled-components"
      ]
    },
    {
      "groupName": "playwright",
      "matchPackageNames": [
        "mcr.microsoft.com/playwright",
        "/^com\\.microsoft\\.playwright/"
      ]
    },
    {
      "description": "Block major/minor updates for react-bootstrap compat-sensitive deps",
      "matchPackageNames": [
        "org.mvnpm:react",
        "org.mvnpm:react-dom",
        "org.mvnpm:react-bootstrap",
        "org.mvnpm:classnames",
        "org.mvnpm:hooks",
        "org.mvnpm.at.types:react",
        "org.mvnpm:styled-components"
      ],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    }
  ]
}
